@page "/"
@using MinhasFinancas.Blazor.Components
@attribute [Authorize]

<AppBreadcrumb Items="_items" />

<MudGrid Justify="Justify.Center" Class="my-8">

    <MudItem xs="12">
        <MudCard Elevation="3" Class="pa-6">
            <MudCardContent>
                <MudSelect T="string"
                           Label="Selecione o mês"
                           Value="selectedMonth"
                           ValueChanged="OnMonthChanged"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="mb-6"
                           FullWidth>
                    @foreach (var month in months)
                    {
                        <MudSelectItem Value="@month">@month</MudSelectItem>
                    }
                </MudSelect>

                <MudPaper Class="pa-6 text-center" Elevation="2">
                    <MudText Typo="Typo.h6" Typo-sm="Typo.h5" Class="mb-2">Saldo Atual</MudText>
                    <MudText Class="text-h6 text-sm-h5 text-md-h3 font-bold"
                             Color="@(currentBalance >= 0 ? Color.Success : Color.Error)">
                        @FormatCurrency(currentBalance)
                    </MudText>
                </MudPaper>

                <MudGrid Class="mt-6">
                    <MudItem xs="12" sm="6">
                        <MudPaper Elevation="2" Class="pa-4 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp"
                                     Size="Size.Large"
                                     Color="Color.Success"
                                     Class="mb-2" />
                            <MudText Typo="Typo.h6" Class="mb-1">Receitas</MudText>
                            <MudText Class="text-h6 text-sm-h5 font-bold"
                                     Color="Color.Success">
                                @FormatCurrency(totalRevenue)
                            </MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudPaper Elevation="2" Class="pa-4 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingDown"
                                     Size="Size.Large"
                                     Color="Color.Error"
                                     Class="mb-2" />
                            <MudText Typo="Typo.h6" Class="mb-1">Despesas</MudText>
                            <MudText Class="text-h6 text-sm-h5 font-bold"
                                     Color="Color.Error">
                                @FormatCurrency(totalExpense)
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudCard Elevation="3" Class="pa-6">
            <MudCardContent>
                <MudText Typo="Typo.h6" Typo-sm="Typo.h5" Class="mb-2 text-center">
                    Despesas por categoria
                </MudText>

                <MudPaper Class="pa-4">
                    <MudChart T="double" ChartType="ChartType.Donut" Width="100%" Height="300px" ChartSeries="@([data])" ChartLabels="@labels"></MudChart>
                </MudPaper>

            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudCard Elevation="3" Class="pa-6">
            <MudCardContent>

                <MudText Typo="Typo.h6" Typo-sm="Typo.h5" Class="mb-2 text-center">
                    Balanço mensal
                </MudText>

                <MudGrid Class="mt-4">

                    <MudItem xs="3" Class="d-flex justify-center">
                        <MudProgressLinear Vertical="true"
                                           Value="65"
                                           Color="Color.Primary"
                                           Size="Size.Large"
                                           Style="height:160px;">
                            <MudText Typo="Typo.caption" Class="text-center">
                                65%
                            </MudText>
                        </MudProgressLinear>
                    </MudItem>

                    <MudItem xs="9">

                        <MudPaper Class="pa-4 text-center mb-3" Elevation="2">
                            <MudText Class="text-h6 text-sm-h5 text-md-h4 font-bold"
                                     Color="Color.Primary">
                                R$ 2.450
                            </MudText>
                            <MudText Typo="Typo.caption">
                                Saldo atual
                            </MudText>
                        </MudPaper>

                        <MudGrid>
                            <MudItem xs="6">
                                <MudPaper Elevation="2" Class="pa-3 text-center">
                                    <MudText Color="Color.Success">+ R$ 3.200</MudText>
                                    <MudText Typo="Typo.caption">Entradas</MudText>
                                </MudPaper>
                            </MudItem>

                            <MudItem xs="6">
                                <MudPaper Elevation="2" Class="pa-3 text-center">
                                    <MudText Color="Color.Error">- R$ 750</MudText>
                                    <MudText Typo="Typo.caption">Saídas</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>

                    </MudItem>

                </MudGrid>

            </MudCardContent>
        </MudCard>
    </MudItem>

</MudGrid>

@code {
    private List<BreadcrumbItem> _items =
    [
        new("Home", href: "/"),
        new("Dashboard", href: null, disabled: true)
    ];

    private string selectedMonth;
    private List<string> months = new List<string>
    {
        "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho",
        "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"
    };
    
    private decimal currentBalance = 12500.50m;
    private decimal totalRevenue = 18500.75m;
    private decimal totalExpense = 6000.25m;

    protected override void OnInitialized()
    {
        var currentMonth = DateTime.Now.Month;
        selectedMonth = months[currentMonth - 1];

        LoadDataForMonth(selectedMonth);
    }

    private void OnMonthChanged(string newMonth)
    {
        selectedMonth = newMonth;
        LoadDataForMonth(selectedMonth);
        StateHasChanged(); 
    }

    private void LoadDataForMonth(string month)
    {
        switch (month)
        {
            case "Janeiro":
                totalRevenue = 18500.75m;
                totalExpense = 6000.25m;
                break;
            case "Fevereiro":
                totalRevenue = 19200.50m;
                totalExpense = 5800.00m;
                break;
            case "Março":
                totalRevenue = 20100.00m;
                totalExpense = 6200.50m;
                break;
            case "Abril":
                totalRevenue = 17800.25m;
                totalExpense = 5900.75m;
                break;
            default:
                totalRevenue = 18500.75m;
                totalExpense = 6000.25m;
                break;
        }
        
        currentBalance = totalRevenue - totalExpense;
    }

    private string FormatCurrency(decimal value)
    {
        return value.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
    }

    int dataSize = 4;
    public double[] data = { 50, 25, 20, 5 };
    public string[] labels = { "Serviços", "Moradia", "Saúde", "Educação" };

}