@page "/"
@using MinhasFinancas.Blazor.Components
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory

<AppBreadcrumb Items="_items" />

<MudGrid Justify="Justify.Center" Class="my-8">

    <MudItem xs="12">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Filtros</MudText>
                <AppFilter OnDateChanged="OnDateChanged" />
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Resumo Financeiro</MudText>
                
                @if (isLoading)
                {
                    <MudProgressCircular Indeterminate="true" Class="my-4" />
                }
                else
                {
                    <MudPaper Class="pa-6 text-center" Elevation="2">
                        <MudText Typo="Typo.h6" Typo-sm="Typo.h5" Class="mb-2">Saldo Atual</MudText>
                        <MudText Class="text-h6 text-sm-h5 text-md-h3 font-bold"
                                 Color="@GetBalanceColor()">
                            @FormatCurrency(currentBalance)
                        </MudText>
                    </MudPaper>

                    <MudGrid Class="mt-6">
                        <MudItem xs="12" sm="6">
                            <MudPaper Elevation="2" Class="pa-4 text-center">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp"
                                         Size="Size.Large"
                                         Color="Color.Success"
                                         Class="mb-2" />
                                <MudText Typo="Typo.h6" Class="mb-1">Receitas</MudText>
                                <MudText Class="text-h6 text-sm-h5 font-bold"
                                         Color="Color.Success">
                                    @FormatCurrency(totalRevenue)
                                </MudText>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudPaper Elevation="2" Class="pa-4 text-center">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingDown"
                                         Size="Size.Large"
                                         Color="Color.Error"
                                         Class="mb-2" />
                                <MudText Typo="Typo.h6" Class="mb-1">Despesas</MudText>
                                <MudText Class="text-h6 text-sm-h5 font-bold"
                                         Color="Color.Error">
                                    @FormatCurrency(totalExpense)
                                </MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudCard Elevation="3" Style="height: 100%;">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4 text-center">
                    Despesas por Categoria
                </MudText>

                @if (isLoadingChart)
                {
                    <div Class="d-flex justify-center align-center" Style="min-height: 300px;">
                        <MudProgressCircular Indeterminate="true" />
                    </div>
                }
                else if (expensesByCategory.Any())
                {
                    <MudChart T="double"
                              ChartType="ChartType.Donut"
                              Width="100%"
                              Height="350px"
                              ChartSeries="@chartSeries"
                              ChartLabels="@chartLabels" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info">
                        Nenhuma despesa encontrada para este período.
                    </MudAlert>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudCard Elevation="3" Style="height: 100%;">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4 text-center">
                    Balanço Mensal
                </MudText>

                @if (isLoading)
                {
                    <div Class="d-flex justify-center align-center" Style="min-height: 300px;">
                        <MudProgressCircular Indeterminate="true" />
                    </div>
                }
                else
                {
                    <MudGrid>
                        <MudItem xs="12" Class="d-flex justify-center mb-4">
                            <div Class="text-center" Style="width: 100%; max-width: 250px;">
                                <MudText Typo="Typo.subtitle1" Class="mb-2">Percentual do Saldo</MudText>
                            
                                <div Class="d-flex justify-center">
                                    <div Style="height: 200px; width: 60px;">
                                        <MudProgressLinear Vertical="true"
                                                           Value="@GetBalancePercentage()"
                                                           Color="@GetBalanceColor()"
                                                           Size="Size.Large"
                                                           Style="height: 100%; width: 100%; border-radius: 8px;">
                                            <div Class="d-flex flex-column justify-center align-center" Style="height: 100%;">
                                                <MudText Typo="Typo.body2"
                                                         Color="Color.Inherit"
                                                         Class="font-bold">
                                                    @GetBalancePercentage()%
                                                </MudText>
                                            </div>
                                        </MudProgressLinear>
                                    </div>
                                </div>
                            
                                <MudText Typo="Typo.caption" Class="mt-2">
                                    do saldo em relação às receitas
                                </MudText>
                            </div>
                        </MudItem>

                        <MudItem xs="12">
                            <MudPaper Class="pa-4 text-center mb-4" Elevation="2">
                                <MudText Class="text-h6 font-bold"
                                         Color="@GetBalanceColor()">
                                    @FormatCurrency(currentBalance)
                                </MudText>
                                <MudText Typo="Typo.caption">
                                    Saldo do período
                                </MudText>
                            </MudPaper>

                            <MudGrid>
                                <MudItem xs="6">
                                    <MudPaper Elevation="1" Class="pa-3 text-center">
                                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp"
                                                 Size="Size.Small"
                                                 Color="Color.Success" />
                                        <MudText Color="Color.Success" Class="font-bold">
                                            + @FormatCurrency(totalRevenue)
                                        </MudText>
                                        <MudText Typo="Typo.caption">Total Receitas</MudText>
                                    </MudPaper>
                                </MudItem>

                                <MudItem xs="6">
                                    <MudPaper Elevation="1" Class="pa-3 text-center">
                                        <MudIcon Icon="@Icons.Material.Filled.TrendingDown"
                                                 Size="Size.Small"
                                                 Color="Color.Error" />
                                        <MudText Color="Color.Error" Class="font-bold">
                                            - @FormatCurrency(totalExpense)
                                        </MudText>
                                        <MudText Typo="Typo.caption">Total Despesas</MudText>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>
                        </MudItem>
                    </MudGrid>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

</MudGrid>

@code {
    private List<BreadcrumbItem> _items => new()
    {
        new("Home", href: "/"),
        new("Dashboard", href: null, disabled: true)
    };

    private bool isLoading = false;
    private bool isLoadingChart = false;
    
    private decimal currentBalance = 0;
    private decimal totalRevenue = 0;
    private decimal totalExpense = 0;
    
    private Dictionary<string, double> expensesByCategory = new();
    private List<ChartSeries<double>> chartSeries = new();
    private string[] chartLabels = Array.Empty<string>();

    [Inject]
    private ISnackbar Snackbar { get; set; }
    
    protected override async Task OnInitializedAsync()
    {
        await LoadData(DateTime.Now.Month, DateTime.Now.Year);
    }
    
    private async Task OnDateChanged((int Month, int Year) date)
    {
        await LoadData(date.Month, date.Year);
    }
    
    private async Task LoadData(int month, int year)
    {
        isLoading = true;
        isLoadingChart = true;
        StateHasChanged();
        
        try
        {
            await LoadFinancialSummary(month, year);
            await LoadExpensesByCategory(month, year);
            PrepareChartData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao carregar dados: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            isLoadingChart = false;
            StateHasChanged();
        }
    }
    
    private async Task LoadFinancialSummary(int month, int year)
    {
        await Task.Delay(300); // Simulação
        
        // Mock data
        var mockData = new Dictionary<int, (decimal Revenue, decimal Expense)>
        {
            { 1, (18500.75m, 6000.25m) },  // Janeiro
            { 2, (19200.50m, 5800.00m) },  // Fevereiro
            { 3, (20100.00m, 6200.50m) },  // Março
            { 4, (17800.25m, 5900.75m) },  // Abril
            { 5, (19500.00m, 7100.00m) },  // Maio
            { 6, (18800.00m, 5500.00m) },  // Junho
        };
        
        if (mockData.ContainsKey(month))
        {
            totalRevenue = mockData[month].Revenue;
            totalExpense = mockData[month].Expense;
        }
        else
        {
            totalRevenue = 15000.00m;
            totalExpense = 7500.00m;
        }
        
        currentBalance = totalRevenue - totalExpense;
    }
    
    private async Task LoadExpensesByCategory(int month, int year)
    {
        await Task.Delay(300); 
        
        expensesByCategory.Clear();

        switch (month)
        {
            case 1: // Janeiro
                expensesByCategory["Alimentação"] = 1500.00;
                expensesByCategory["Moradia"] = 2500.00;
                expensesByCategory["Transporte"] = 800.00;
                expensesByCategory["Lazer"] = 600.00;
                expensesByCategory["Saúde"] = 450.00;
                break;
            case 2: // Fevereiro
                expensesByCategory["Alimentação"] = 1600.00;
                expensesByCategory["Moradia"] = 2500.00;
                expensesByCategory["Transporte"] = 750.00;
                expensesByCategory["Lazer"] = 400.00;
                expensesByCategory["Educação"] = 550.00;
                break;
            case 3: // Março
                expensesByCategory["Alimentação"] = 1700.00;
                expensesByCategory["Moradia"] = 2600.00;
                expensesByCategory["Transporte"] = 900.00;
                expensesByCategory["Lazer"] = 800.00;
                expensesByCategory["Saúde"] = 500.00;
                expensesByCategory["Educação"] = 600.00;
                break;
            default:
                expensesByCategory["Alimentação"] = 1400.00;
                expensesByCategory["Moradia"] = 2400.00;
                expensesByCategory["Transporte"] = 700.00;
                expensesByCategory["Lazer"] = 500.00;
                expensesByCategory["Saúde"] = 400.00;
                break;
        }
    }
    
    private void PrepareChartData()
    {
        chartSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = "Despesas por Categoria",
                Data = expensesByCategory.Values.ToArray()
            }
        };
        
        chartLabels = expensesByCategory.Keys.ToArray();
    }
    
    private double GetBalancePercentage()
    {
        if (totalRevenue == 0) return 0;
        var percentage = (double)(currentBalance / totalRevenue * 100);
        return Math.Max(0, Math.Min(100, percentage));
    }
    
    private Color GetBalanceColor()
    {
        return currentBalance >= 0 ? Color.Success : Color.Error;
    }
    
    private string FormatCurrency(decimal value)
    {
        return value.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
    }
}