@page "/login"
@layout LayoutLogin
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using MinhasFinancas.Common.DTOs.Account
@attribute [AllowAnonymous]

@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height:100vh;">
    
    <MudPaper Class="pa-6" Elevation="8" Style="width:100%; border-radius:18px;">

        <MudStack Spacing="3">

            <MudText Typo="Typo.h4" Align="Align.Center" Color="Color.Primary">
                Minhas Finanças 
            </MudText>

            <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-2">
                Faça login para continuar
            </MudText>

            <MudForm @ref="_form">

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                        @errorMessage
                    </MudAlert>
                }

                <MudTextField T="string"
                              Label="E-mail"
                              @bind-Value="loginModel.Email"
                              Required="true"
                              RequiredError="E-mail é obrigatório"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              Class="mb-2" />

                <MudTextField T="string"
                              Label="Senha"
                              @bind-Value="loginModel.Password"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Required="true"
                              RequiredError="Senha é obrigatória"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="TogglePassword"
                              Class="mb-1" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Class="mt-2"
                           Disabled="@isLoading"
                           OnClick="HandleLogin">

                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                        <span>Entrando...</span>
                    }
                    else
                    {
                        <span>Entrar</span>
                    }

                </MudButton>

            </MudForm>

            <MudDivider />

            <MudText Typo="Typo.caption" Align="Align.Center">
                Não tem conta?
                <MudLink Href="/cadastro">Cadastre-se</MudLink>
            </MudText>

        </MudStack>

    </MudPaper>

</MudContainer>


@code {
    private LoginDto loginModel = new();
    private bool isLoading = false;
    private string errorMessage = string.Empty;
    private MudForm? _form;
    private bool _showPassword;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

    private async Task HandleLogin()
    {
        await _form!.ValidateAsync();

        if (!_form.IsValid)
            return;

        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var httpClient = HttpClientFactory.CreateClient("ApiClient");

            var response = await httpClient.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                var authResponse = await response.Content.ReadFromJsonAsync<AuthResponseDto>();

                if (authResponse?.AuthToken != null)
                {
                    var provider = (CustomAuthStateProvider)AuthProvider;
                    await provider.MarkUserAsAuthenticated(authResponse.AuthToken);

                    var redirectUrl = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
                    Navigation.NavigateTo(redirectUrl, forceLoad: true);
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "E-mail ou senha inválidos";
            }
            else
            {
                errorMessage = "Erro ao fazer login. Tente novamente.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro de conexão: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}