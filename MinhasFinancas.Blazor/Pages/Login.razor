@page "/login"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using MinhasFinancas.Common.DTOs.Account
@attribute [AllowAnonymous]

@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<MudGrid Justify="Justify.Center" Class="mt-6">
    <MudItem xs="12" sm="8" md="5" lg="4">

        <MudPaper Class="pa-6" Elevation="4">

            <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Primary">
                Minhas Finanças
            </MudText>

            <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-4">
                Faça login para continuar
            </MudText>

            <MudForm @ref="_form">

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">
                        @errorMessage
                    </MudAlert>
                }

                <MudTextField T="string"
                              Label="E-mail"
                              @bind-Value="loginModel.Email"
                              Required="true"
                              RequiredError="E-mail é obrigatório"
                              Variant="Variant.Filled"
                              Class="mb-3" />

                <MudTextField T="string"
                              Label="Senha"
                              @bind-Value="loginModel.Password"
                              InputType="InputType.Password"
                              Required="true"
                              RequiredError="Senha é obrigatória"
                              Variant="Variant.Filled"
                              Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@isLoading"
                           OnClick="HandleLogin">

                    @(isLoading ? "Entrando..." : "Entrar")

                </MudButton>

            </MudForm>

            <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-4">
                Não tem conta?
                <MudLink Href="/cadastro">Cadastre-se</MudLink>
            </MudText>

        </MudPaper>

    </MudItem>
</MudGrid>

@code {
    private LoginDto loginModel = new();
    private bool isLoading = false;
    private string errorMessage = string.Empty;
    private MudForm? _form;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private async Task HandleLogin()
    {
        await _form!.ValidateAsync();

        if (!_form.IsValid)
            return;

        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var httpClient = HttpClientFactory.CreateClient("ApiClient");

            var response = await httpClient.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                var authResponse = await response.Content.ReadFromJsonAsync<AuthResponseDto>();

                if (authResponse?.AuthToken != null)
                {
                    var provider = (CustomAuthStateProvider)AuthProvider;
                    await provider.MarkUserAsAuthenticated(authResponse.AuthToken);

                    var redirectUrl = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
                    Navigation.NavigateTo(redirectUrl, forceLoad: true);
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "E-mail ou senha inválidos";
            }
            else
            {
                errorMessage = "Erro ao fazer login. Tente novamente.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro de conexão: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}